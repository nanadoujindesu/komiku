# ============================================
# Komiku Mirror — Environment Configuration
# ============================================

# --- Server ---
PORT=3000

# --- Mirror Domain ---
# Your mirror domain (without protocol). Used for canonical URLs,
# structured data, and all URL rewrites. REQUIRED for SEO.
MIRROR_DOMAIN=komiku.io
MIRROR_PROTOCOL=https

# --- Origin ---
ORIGIN_HOST=komiku.org
ORIGIN_PROTOCOL=https

# --- Image / CDN Domains ---
# Comma-separated list of additional domains whose assets should be
# proxied through /_img/. Subdomains are auto-matched.
IMAGE_DOMAINS=cdn.komiku.co.id,komiku.co.id,i.komiku.org,thumbnail.komiku.org,update.komikid.org,i0.wp.com,i1.wp.com,i2.wp.com,i3.wp.com

# --- Cache TTL (seconds) ---
CACHE_TTL_HTML=300
CACHE_TTL_ASSETS=86400
CACHE_TTL_IMAGES=604800
CACHE_MAX_ITEMS=2000

# --- Browser Mode (optional) ---
# Set to "true" to enable puppeteer-stealth for Cloudflare-protected
# resources. Requires Chromium in the container (see Dockerfile).
USE_BROWSER=false

# --- Logging ---
LOG_LEVEL=info
